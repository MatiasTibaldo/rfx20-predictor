# ============================================================
# RFX20 Predictor — .gitignore
# ============================================================

# --- Project data and outputs (never commit raw/processed data) ---
data/
results/

# --- Environment and secrets ---
.env
.envrc

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.egg-info/
*.egg
MANIFEST
dist/
build/
.eggs/
wheels/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- OS ---
.DS_Store
Thumbs.db

# --- Tools ---
.ruff_cache/
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/
.hypothesis/
*.log

# --- Jupyter ---
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# --- uv ---
# uv.lock is intentionally kept in version control for reproducibility.
# Uncomment the next line only if this is a library (not an application).
# uv.lock
