# ============================================================
# RFX20 Predictor — environment variables
# Copy this file to .env and fill in your values.
# .env is never committed to version control.
# ============================================================

# --- Paths (optional: defaults are relative to the project root) ---
# DATA_DIR=/absolute/path/to/data
# RESULTS_DIR=/absolute/path/to/results
# DB_PATH=/absolute/path/to/experiments.duckdb

# --- Data splits ---
# TRAIN_RATIO=0.70
# VAL_RATIO=0.15
# TEST_RATIO=0.15

# --- Modelling ---
# Comma-separated list of business-day horizons to forecast
# PREDICTION_HORIZONS=[1,3,5]

# Feature groups to activate (empty = none loaded yet)
# ACTIVE_FEATURES=["technical","macro"]

# --- Observability ---
# LOG_LEVEL=INFO   # DEBUG | INFO | WARNING | ERROR | CRITICAL

# --- External data sources (fill in when integrating) ---
# ALPHA_VANTAGE_API_KEY=your_key_here
# BYMA_API_KEY=your_key_here

# --- Primary S.A. API ---
PRIMARY_USER=tu_usuario
PRIMARY_PASS=tu_password
PRIMARY_BASE_URL=https://matriz.lbo.xoms.com.ar
# PRIMARY_TIMEOUT=30
# PRIMARY_MAX_RETRIES=3
